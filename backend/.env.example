# 服务器配置
# 监听端口（默认：3000）
PORT=3000

# 绑定地址（默认：0.0.0.0，表示所有网络接口）
HOSTNAME=0.0.0.0

# 运行环境（development | production）
NODE_ENV=production

# SQLite 数据库文件路径（默认：./nova-tasks.sqlite）
NOVA_TASK_DB=./nova-tasks.sqlite

# 最大并发图片数
NOVA_TASK_CONCURRENCY=50

# 全局上游 API 基础地址（配置后会覆盖页面模型里的 Base URL）
NOVA_API_BASE_URL=

# 是否锁定页面上的 API 基础地址输入框：true=只读，其他值=可编辑
NOVA_API_BASE_URL_LOCK=false

# 是否保留服务端生成图片：true=保留，其他值=前端取完后立即删除服务端临时图片
NOVA_SAVE_IMAGE_ENABLED=false

# ============================================
# 队列与限流配置（由系统环境变量注入，修改后需重启服务）
# ============================================

# 全局最大待处理任务数（排队中 + 生成中），达到后返回 503 QUEUE_FULL
NOVA_MAX_QUEUE_SIZE=200

# 限流窗口长度（毫秒）
NOVA_RATE_LIMIT_WINDOW_MS=60000

# 单 IP 在一个窗口内最多创建多少个任务，超过返回 429 RATE_LIMITED
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_IP=10

# 单 API Key 在一个窗口内最多创建多少个任务，超过返回 429 RATE_LIMITED
NOVA_RATE_LIMIT_MAX_REQUESTS_PER_API_KEY=10

# 单 IP 最多同时拥有多少个待处理任务，超过返回 429 TOO_MANY_PENDING_TASKS
NOVA_MAX_PENDING_TASKS_PER_IP=20

# 单 API Key 最多同时拥有多少个待处理任务，超过返回 429 TOO_MANY_PENDING_TASKS
NOVA_MAX_PENDING_TASKS_PER_API_KEY=20

# 队列满/限流时返回给客户端的 Retry-After 秒数
NOVA_RATE_LIMIT_RETRY_AFTER_SECONDS=60

# ============================================
# 提示词广场配置
# ============================================

# 提示词广场模式：1=常驻（直接显示） 2=私密（需密码验证，点七下标题） 3=关闭（完全隐藏）
# 修改后需重启服务
PROMPT_GALLERY_MODE=1
PROMPT_GALLERY_PASSWORD=8848
